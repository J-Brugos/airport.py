def map_flights():
    if not aircrafts:
        messagebox.showerror("Error", "No arrivals loaded")
        return

    filename = filedialog.asksaveasfilename(defaultextension=".kml")

    if not filename:
        return

    MapFlights(aircrafts, filename)
